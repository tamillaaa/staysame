# Copy to .env.local and fill in. .env.local is gitignored.

# --- AI ---
# Itinerary generation (Claude). https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Image-to-destination vision analysis. https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Travel data ---
# Hotel search. https://hub.stay22.com
# Optional: without it the Stay22 API runs in demo mode (5 requests/minute).
STAY22_API_KEY=
# Affiliate ID for Allez booking-link attribution.
STAY22_AID=
# Top-rated spots. https://console.cloud.google.com/apis/credentials
GOOGLE_PLACES_API_KEY=
# Live events. https://developer.ticketmaster.com
TICKETMASTER_API_KEY=

# --- Voice narration (stretch goal — not wired up yet) ---
ELEVENLABS_API_KEY=

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to the browser — bypasses row-level security.
SUPABASE_SERVICE_ROLE_KEY=

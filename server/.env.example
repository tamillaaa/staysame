# Copy this file to .env and fill in your keys. .env is gitignored.

# Required. Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Optional. Defaults to gemini-3.5-flash. Note that gemini-2.5-flash is retired
# and returns 404 for new API keys.
GEMINI_MODEL=

# Optional. Stay22 Direct Travel API key from https://hub.stay22.com
# Without it the server falls back to Stay22's keyless demo mode, which works
# but is capped at 5 requests/minute.
STAY22_API_KEY=your-stay22-api-key-here

# Optional. Stay22 affiliate ID for booking-commission attribution.
STAY22_AID=

# Optional. Defaults to 3001.
PORT=3001
